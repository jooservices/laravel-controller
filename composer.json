{
    "name": "jooservices/laravel-controller",
    "description": "Base API Controller with standardized responses and automatic versioning",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "JOO Services",
            "email": "dev@jooservices.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^12.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.10",
        "phpmd/phpmd": "^2.15",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "JOOservices\\LaravelController\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "App\\": "tests/Fixtures/App/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint; vendor/bin/phpstan analyse --memory-limit=512M; php -d error_reporting=24575 vendor/bin/phpmd src text phpmd.xml; vendor/bin/phpcs",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M"
    },
    "extra": {
        "laravel": {
            "providers": [
                "JOOservices\\LaravelController\\Providers\\LaravelControllerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}